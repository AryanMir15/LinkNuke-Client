---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../../../src/Landing-page/Navbar.jsx';
import Hero from '../../../src/Landing-page/Hero.jsx';
import Features from '../../../src/Landing-page/Features.jsx';
import PainPoints from '../../../src/Landing-page/PainPoints.jsx';
---

<MainLayout title="LinkNuke - Self-Destructing Links" description="Share sensitive files and links that automatically delete themselves">
	<Navbar client:load />
	<Hero client:visible />
	<Features client:visible />
	<PainPoints client:visible />
	<div className="text-center py-20">
		<h1 className="text-4xl font-bold text-white mb-4">LinkNuke</h1>
		<p className="text-gray-300 text-lg">Secure link-sharing platform</p>
	</div>
</MainLayout>
