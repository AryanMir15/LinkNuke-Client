---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Dashboard - LinkNuke" description="Access your LinkNuke dashboard to manage links and view analytics.">
	<head>
		<meta name="google-site-verification" content="MTN8Q0HJI2d4tr8opC3VuBcimT7BNkdy1coLLCJ8zO0" />
	</head>
	<div class="flex items-center justify-center min-h-screen">
		<div class="text-center">
			<h1 class="text-2xl font-bold text-white mb-4">Dashboard Loading...</h1>
			<p class="text-gray-400">Please wait while we load your dashboard.</p>
			<div class="mt-8">
				<a href="/" class="bg-[#1de4bf] text-black px-6 py-3 rounded-lg font-semibold hover:bg-[#1de4bf]/90 transition-colors">
					Return to Home
				</a>
			</div>
		</div>
	</div>
</MainLayout>
